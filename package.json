<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>학급</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%F0%9F%A5%9A%3C/text%3E%3C/svg%3E">
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f1f5f9;
      margin: 0;
      padding: 20px;
    }
    h1 { margin-bottom: 18px; }

    /* TOP BAR */
    .top-bar {
      display: flex;
      justify-content: space-between;
      margin-bottom: 18px;
      gap: 10px;
    }
    .btn-group { display: flex; gap: 10px; }
    .btn {
      border: none;
      border-radius: 14px;
      padding: 12px 16px;
      color: white;
      font-weight: bold;
      cursor: pointer;
      transition: 0.1s;
    }
    .btn:active { transform: scale(0.96); }
    .home-btn { background: #475569; }
    .all-btn { background: #6366f1; }
    .sheet-btn { background: #16a34a; }
    .check-mode-btn { background: #f97316; }
    .check-mode-btn.active { background: #ea580c; box-shadow: inset 0 0 0 2px #fff; }

    /* GRID */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
      gap: 12px;
    }

    /* CARD */
    .card {
      background: white;
      border-radius: 22px;
      padding: 14px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      position: relative;
      transition: background 0.15s ease, box-shadow 0.15s ease;
    }
    .card.hatchable {
      background: #fff7ed;
      box-shadow: inset 0 0 0 2px #facc15;
    }
    .card.selected {
      background: #eff6ff;
      box-shadow: inset 0 0 0 3px #3b82f6;
    }
    .card.check-mode {
      cursor: pointer;
    }
    .inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .name { font-size: 20px; font-weight: bold; }
    .info { font-size: 13px; color: #64748b; margin-top: 4px; }
    .egg { font-size: 14px; margin-top: 6px; }
    .collection-btn {
      cursor: pointer;
      transition: transform 0.12s ease, opacity 0.12s ease;
    }
    .collection-btn:hover { transform: scale(1.06); opacity: 0.8; }

    /* MAIN BUTTON */
    .main-btn {
      width: 80px;
      height: 80px;
      border: none;
      border-radius: 22px;
      font-size: 36px;
      cursor: pointer;
      transition: transform 0.08s ease, filter 0.08s ease;
    }
    .main-btn:active { transform: scale(0.86); filter: brightness(0.9); }
    .btn-common { background: #e2e8f0; }
    .btn-rare { background: #bfdbfe; }
    .btn-legendary { background: #fde68a; }

    /* POPUP */
    .popup {
      position: absolute;
      right: 10px;
      top: 10px;
      background: #fef3c7;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 12px;
      animation: pop 1.5s forwards;
    }
    @keyframes pop {
      0% { opacity: 0; transform: translateY(10px); }
      20% { opacity: 1; }
      100% { opacity: 0; transform: translateY(-10px); }
    }

    /* MODAL */
    .modal {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 999;
    }
    .modal-content {
      position: relative;
      background: white;
      padding: 50px 40px;
      border-radius: 28px;
      text-align: center;
      width: 420px;
      min-height: 420px;
      overflow: visible;
      transition: background 0.3s ease, transform 0.25s ease;
    }
    .collection-modal-content {
      max-height: 80vh;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: #cbd5e1 transparent;
    }
    .collection-modal-content::-webkit-scrollbar {
      width: 6px;
    }
    .collection-modal-content::-webkit-scrollbar-track {
      background: transparent;
    }
    .collection-modal-content::-webkit-scrollbar-thumb {
      background-color: #cbd5e1;
      border-radius: 10px;
    }

    /* BULK ACTION BAR */
    .bulk-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: white;
      box-shadow: 0 -4px 16px rgba(0,0,0,0.12);
      padding: 14px 20px;
      display: none;
      justify-content: center;
      align-items: center;
      gap: 14px;
      z-index: 998;
    }
    .bulk-bar.show { display: flex; }
    .bulk-bar span { font-size: 14px; color: #475569; font-weight: bold; }
    .bulk-confirm-btn {
      background: #3b82f6;
      color: white;
      border: none;
      border-radius: 14px;
      padding: 10px 18px;
      font-weight: bold;
      cursor: pointer;
    }
    .bulk-select-all-btn {
      background: #e2e8f0;
      color: #1e293b;
      border: none;
      border-radius: 14px;
      padding: 10px 18px;
      font-weight: bold;
      cursor: pointer;
    }
    #hatchStage {
      min-height: 220px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .reward-img { font-size: 90px; }
    .reward-name { font-size: 32px; font-weight: bold; margin-top: 14px; }
    .close {
      margin-top: 30px;
      padding: 12px 18px;
      border: none;
      border-radius: 12px;
      cursor: pointer;
    }

    /* HATCH EFFECT */
    .hidden { display: none; }
    .egg-anim { font-size: 96px; cursor: pointer; user-select: none; }
    .shake { animation: shakeEgg 0.7s infinite; }
    @keyframes shakeEgg {
      0% { transform: rotate(0deg); }
      20% { transform: rotate(-10deg); }
      40% { transform: rotate(10deg); }
      60% { transform: rotate(-8deg); }
      80% { transform: rotate(8deg); }
      100% { transform: rotate(0deg); }
    }
    .silhouette { font-size: 90px; filter: brightness(0); }
    .flash-common { background: #fef3c7; }
    .flash-rare { background: #bfdbfe; }
    .flash-legendary {
      background: linear-gradient(135deg, #111827, #312e81, #0f172a);
      color: white;
    }
    .reveal { animation: revealAnim 0.4s ease; }
    @keyframes revealAnim {
      0% { transform: scale(0.4); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }

    /* PARTICLES */
    #legendParticles {
      position: fixed;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
      z-index: 5000;
    }
    .rare-particle {
      position: absolute;
      animation: rareFloat 1.8s ease-out forwards;
      opacity: 0;
    }
    @keyframes rareFloat {
      0% { transform: scale(0.5) translateY(10px); opacity: 0; }
      30% { opacity: 0.9; }
      100% { transform: scale(1.2) translateY(-30px); opacity: 0; }
    }
    .chaos-particle {
      position: absolute;
      animation: chaosMove 2.2s linear forwards;
      opacity: 0;
    }
    @keyframes chaosMove {
      0% { transform: translate(0,0) rotate(0deg) scale(0.5); opacity: 0; }
      10% { opacity: 1; }
      100% { transform: translate(var(--dx), var(--dy)) rotate(var(--rot)) scale(1.4); opacity: 0; }
    }

    /* COLLECTION */
    .collection-grid {
      display: grid;
      grid-template-columns: repeat(4, 84px);
      justify-content: center;
      gap: 14px;
      margin-top: 24px;
    }
    .collection-item {
      width: 84px;
      height: 84px;
      border-radius: 22px;
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
      font-size: 42px;
      font-weight: bold;
      box-sizing: border-box;
      border: 3px solid rgba(255,255,255,0.22);
      transition: transform 0.12s ease, box-shadow 0.12s ease;
    }
    .collection-item:hover { transform: scale(1.06); }
    .collection-common { background: #d1d5db; color: #111827; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.5); }
    .collection-rare { background: #2563eb; color: white; box-shadow: 0 0 16px rgba(59,130,246,0.75), 0 0 32px rgba(59,130,246,0.35); }
    .collection-legendary { background: linear-gradient(135deg, #facc15, #f59e0b); color: white; box-shadow: 0 0 22px rgba(250,204,21,0.95), 0 0 46px rgba(250,204,21,0.5); }
    .collection-item.locked { font-size: 40px; }
    .collection-common.locked { background: #6b7280; color: white; box-shadow: inset 0 0 0 2px rgba(255,255,255,0.08); }
    .collection-rare.locked { background: #1d4ed8; color: white; box-shadow: 0 0 20px rgba(59,130,246,0.95), 0 0 40px rgba(59,130,246,0.4); }
    .collection-legendary.locked { background: linear-gradient(135deg, #a16207, #f59e0b); color: #fff8dc; box-shadow: 0 0 28px rgba(250,204,21,1), 0 0 56px rgba(250,204,21,0.55); }



    /* TOOLTIP */
    .tooltip {
      display: none;
      position: absolute;
      bottom: calc(100% + 8px);
      left: 50%;
      transform: translateX(-50%);
      background: #1e293b;
      color: white;
      font-size: 12px;
      border-radius: 10px;
      padding: 7px 10px;
      white-space: nowrap;
      z-index: 100;
      pointer-events: none;
      line-height: 1.6;
      text-align: left;
    }
    .tooltip::after {
      content: '';
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border: 5px solid transparent;
      border-top-color: #1e293b;
    }
    .collection-item:hover .tooltip {
      display: block;
    }
  </style>
</head>
<body>

<h1 id="pageTitle">🥚 학급</h1>

<div class="top-bar">
  <div class="btn-group">
    <button class="btn home-btn" onclick="goHome()">← 홈</button>
    <button class="btn all-btn" onclick="openClassCollection()">🏫 학급 도감</button>
    <button id="checkModeBtn" class="btn check-mode-btn" onclick="toggleCheckMode()">✅ 참여 체크 모드</button>
  </div>
  <div class="btn-group">
    <button class="btn sheet-btn" onclick="openSheet()">📊 스프레드시트</button>
  </div>
</div>

<div id="grid" class="grid"></div>

<!-- HATCH MODAL -->
<div id="modal" class="modal">
  <div id="modalContent" class="modal-content">
    <div id="hatchStage">
      <div id="eggAnim" class="egg-anim" onclick="startReveal()">🥚</div>
      <div id="silhouette" class="silhouette hidden">❓</div>
      <div id="rewardImg" class="reward-img hidden"></div>
      <div id="rewardName" class="reward-name"></div>
    </div>
    <button class="close" onclick="closeModal()">닫기</button>
  </div>
</div>

<!-- COLLECTION MODAL -->
<div id="collectionModal" class="modal">
  <div class="modal-content collection-modal-content">
    <h2 id="collectionTitle"></h2>
    <div id="collectionList"></div>
    <button class="close" onclick="closeCollectionModal()">닫기</button>
  </div>
</div>

<!-- BULK ACTION BAR -->
<div id="bulkBar" class="bulk-bar">
  <span id="bulkCount">선택 0명</span>
  <button class="bulk-select-all-btn" onclick="selectAllStudents()">전체 선택</button>
  <button class="bulk-confirm-btn" onclick="confirmBulkPresentation()">참여 점수 부여</button>
</div>

<div id="legendParticles"></div>

<script>
// URL 파라미터 파싱
const params = new URLSearchParams(window.location.search);
const GRADE = params.get('grade');
const CLASS_NUM = params.get('class');

document.getElementById('pageTitle').innerText = `🥚 ${GRADE}학년 ${CLASS_NUM}반`;
document.title = `${GRADE}학년 ${CLASS_NUM}반`;

let students = [];
let lock = false;
let currentReward = null;
let checkMode = false;
let selectedIds = new Set();

/* =========================
   초기 로딩
========================= */
async function loadStudents() {
  try {
    const res = await fetch(`/api/students?grade=${GRADE}&classNum=${CLASS_NUM}`);
    students = await res.json();
    renderAll();
  } catch (err) {
    console.error('학생 로딩 실패:', err);
  }
}

/* =========================
   전체 렌더
========================= */
function renderAll() {
  const grid = document.getElementById('grid');
  grid.innerHTML = '';
  students.forEach(s => {
    const card = document.createElement('div');
    card.className = getCardClassName(s);
    card.id = `card-${s.studentId}`;
    card.innerHTML = getCardHTML(s);
    if (checkMode) {
      card.onclick = () => toggleSelect(s.studentId);
    }
    grid.appendChild(card);
  });
}

function getCardClassName(s) {
  let cls = 'card';
  if (s.eggs > 0) cls += ' hatchable';
  if (checkMode) cls += ' check-mode';
  if (selectedIds.has(String(s.studentId))) cls += ' selected';
  return cls;
}

/* =========================
   카드 HTML
========================= */
function getCardHTML(s) {
  const onClickAttr = checkMode ? '' : `onclick="handle('${s.studentId}')"`;
  return `
    <div class="inner">
      <div>
        <div class="name">${s.name}</div>
        <div class="info">발표 ${s.presentationCount ?? 0}회</div>
        <div class="egg collection-btn" onclick="event.stopPropagation(); openCollection('${s.studentId}', '${s.name}')">
          📖 ${s.totalHatch}
        </div>
      </div>
      <button class="main-btn btn-${s.lastRewardRarity || 'common'}" ${onClickAttr} ${checkMode ? 'style="pointer-events:none;"' : ''}>
        ${s.lastRewardImage || '🥚'}
      </button>
    </div>
  `;
}

function handle(id) {
  if (lock) return;
  lock = true;
  setTimeout(() => { lock = false; }, 250);

  const s = students.find(x => x.studentId == id);
  if (!s) return;

  if (s.eggs > 0) {
    hatch(id);
  } else {
    present(id);
  }
}

async function present(id) {
  try {
    const res = await fetch('/api/presentation', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ studentId: id }),
    });
    const data = await res.json();
    updateStudent(id, data);
    if (data.eggEarned) showPopup(id);
  } catch (err) {
    console.error('발표 추가 실패:', err);
  }
}

async function hatch(id) {
  try {
    const res = await fetch('/api/hatch', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ studentId: id }),
    });
    const data = await res.json();
    if (!data.success) return;
    currentReward = { ...data, studentId: id };
    openEggModal();
  } catch (err) {
    console.error('부화 실패:', err);
  }
}

function openEggModal() {
  const modal = document.getElementById('modal');
  const modalContent = document.getElementById('modalContent');
  const egg = document.getElementById('eggAnim');
  const silhouette = document.getElementById('silhouette');
  const rewardImg = document.getElementById('rewardImg');
  const rewardName = document.getElementById('rewardName');
  const particles = document.getElementById('legendParticles');

  particles.innerHTML = '';
  modal.style.display = 'flex';
  modalContent.classList.remove('flash-common', 'flash-rare', 'flash-legendary');
  egg.className = 'egg-anim shake';
  egg.classList.remove('hidden');
  silhouette.className = 'silhouette hidden';
  rewardImg.className = 'reward-img hidden';
  rewardName.innerText = '';
  egg.onclick = startReveal;
}

function startReveal() {
  if (!currentReward) return;

  const rarity = currentReward.reward.rarity;
  const modalContent = document.getElementById('modalContent');
  const egg = document.getElementById('eggAnim');
  const silhouette = document.getElementById('silhouette');
  const rewardImg = document.getElementById('rewardImg');
  const rewardName = document.getElementById('rewardName');

  egg.onclick = null;
  modalContent.classList.add(`flash-${rarity}`);
  silhouette.classList.remove('hidden');
  egg.classList.add('hidden');
  playRarityEffect(rarity);

  setTimeout(() => {
    silhouette.classList.add('hidden');
    rewardImg.innerText = currentReward.reward.image;
    rewardImg.classList.remove('hidden');
    rewardName.innerText = currentReward.reward.name;
  }, rarity === 'legendary' ? 4800 : rarity === 'rare' ? 2200 : 1400);

  updateStudent(currentReward.studentId, {
    eggs: currentReward.eggs,
    totalHatch: currentReward.totalHatch,
    lastReward: currentReward.reward.name,
    lastRewardImage: currentReward.reward.image,
    lastRewardRarity: currentReward.reward.rarity,
  });
}

function playRarityEffect(rarity) {
  const container = document.getElementById('legendParticles');
  container.innerHTML = '';

  if (rarity === 'rare') {
    const icons = ['✨','💎','❄️'];
    for (let i = 0; i < 30; i++) {
      const p = document.createElement('div');
      p.className = 'rare-particle';
      p.innerText = icons[Math.floor(Math.random() * icons.length)];
      p.style.fontSize = (60 + Math.random() * 24) + 'px';
      p.style.left = (20 + Math.random() * 60) + '%';
      p.style.top = (25 + Math.random() * 50) + '%';
      p.style.animationDelay = (i * 0.1) + 's';
      container.appendChild(p);
      setTimeout(() => p.remove(), 2200);
    }
  }

  if (rarity === 'legendary') {
    const icons = ['🛸','👁️','⚡','💥','✨','🌙','💫'];
    for (let i = 0; i < 80; i++) {
      const p = document.createElement('div');
      p.className = 'chaos-particle';
      p.innerText = icons[Math.floor(Math.random() * icons.length)];
      p.style.fontSize = (122 + Math.random() * 46) + 'px';
      p.style.left = Math.random() * 100 + '%';
      p.style.top = Math.random() * 100 + '%';
      p.style.setProperty('--dx', ((Math.random() - 0.5) * 1400) + 'px');
      p.style.setProperty('--dy', ((Math.random() - 0.5) * 1000) + 'px');
      p.style.setProperty('--rot', ((Math.random() - 0.5) * 720) + 'deg');
      p.style.animationDelay = (i * 0.05) + 's';
      container.appendChild(p);
      setTimeout(() => p.remove(), 5000);
    }
  }
}

function updateStudent(id, data) {
  const s = students.find(x => x.studentId == id);
  if (!s) return;
  Object.assign(s, data);

  const card = document.getElementById(`card-${id}`);
  if (!card) return;
  card.className = getCardClassName(s);
  card.innerHTML = getCardHTML(s);
  if (checkMode) {
    card.onclick = () => toggleSelect(s.studentId);
  }
}

/* =========================
   참여 체크 모드
========================= */
function toggleCheckMode() {
  checkMode = !checkMode;
  selectedIds.clear();

  const btn = document.getElementById('checkModeBtn');
  btn.classList.toggle('active', checkMode);
  btn.innerText = checkMode ? '✅ 체크 모드 끄기' : '✅ 참여 체크 모드';

  document.getElementById('bulkBar').classList.toggle('show', checkMode);
  updateBulkCount();
  renderAll();
}

function toggleSelect(id) {
  const key = String(id);
  if (selectedIds.has(key)) {
    selectedIds.delete(key);
  } else {
    selectedIds.add(key);
  }
  updateBulkCount();

  const s = students.find(x => x.studentId == id);
  const card = document.getElementById(`card-${id}`);
  if (card && s) card.className = getCardClassName(s);
}

function selectAllStudents() {
  students.forEach(s => selectedIds.add(String(s.studentId)));
  updateBulkCount();
  renderAll();
}

function updateBulkCount() {
  document.getElementById('bulkCount').innerText = `선택 ${selectedIds.size}명`;
}

async function confirmBulkPresentation() {
  if (selectedIds.size === 0) return;

  const ids = Array.from(selectedIds);

  try {
    const res = await fetch('/api/bulk-presentation', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ studentIds: ids }),
    });
    const data = await res.json();
    if (!data.success) return;

    selectedIds.clear();
    updateBulkCount();
    await loadStudents();

    data.eggEarnedStudents.forEach((x, i) => {
      setTimeout(() => showPopup(x.studentId), i * 120);
    });
  } catch (err) {
    console.error('참여 점수 일괄 부여 실패:', err);
  }
}

/* =========================
   스프레드시트 바로가기
========================= */
async function openSheet() {
  try {
    const res = await fetch('/api/config');
    const data = await res.json();
    window.open(`https://docs.google.com/spreadsheets/d/${data.spreadsheetId}/edit`, '_blank');
  } catch (err) {
    console.error('스프레드시트 링크 로딩 실패:', err);
  }
}

function showPopup(id) {
  const card = document.getElementById(`card-${id}`);
  if (!card) return;
  const p = document.createElement('div');
  p.className = 'popup';
  p.innerText = '🥚 획득!';
  card.appendChild(p);
  setTimeout(() => p.remove(), 1500);
}



function goHome() {
  window.location.href = '/';
}

function closeModal() {
  document.getElementById('modal').style.display = 'none';
  currentReward = null;
}

/* =========================
   COLLECTION
========================= */
async function openCollection(studentId, name) {
  try {
    const res = await fetch(`/api/collection?type=student&studentId=${studentId}`);
    const data = await res.json();

    const modal = document.getElementById('collectionModal');
    document.getElementById('collectionTitle').innerText = name;

    const list = document.getElementById('collectionList');
    if (data.length === 0) {
      list.innerHTML = '아직 부화 기록이 없습니다.';
    } else {
      list.innerHTML = `
        <div class="collection-grid">
          ${data.map(x => `
            <div class="collection-item collection-${x.rarity}">${x.image}</div>
          `).join('')}
        </div>
      `;
    }
    modal.style.display = 'flex';
  } catch (err) {
    console.error('도감 로딩 실패:', err);
  }
}

function closeCollectionModal() {
  document.getElementById('collectionModal').style.display = 'none';
}

async function openClassCollection() {
  try {
    const res = await fetch(`/api/collection?type=class&grade=${GRADE}&classNum=${CLASS_NUM}`);
    const data = await res.json();

    const modal = document.getElementById('collectionModal');
    document.getElementById('collectionTitle').innerText = `${GRADE}학년 ${CLASS_NUM}반`;

    document.getElementById('collectionList').innerHTML = `
      <div class="collection-grid">
        ${data.map(x => {
          const tooltipContent = x.obtained
            ? `<div class="tooltip"><strong>${x.name}</strong><br>${x.obtainedBy.map((n, i) => `${i+1}. ${n}`).join('<br>')}</div>`
            : `<div class="tooltip">???</div>`;
          return `
            <div class="collection-item collection-${x.rarity} ${x.obtained ? '' : 'locked'}">
              ${x.obtained ? x.image : '?'}
              ${tooltipContent}
            </div>
          `;
        }).join('')}
      </div>
    `;
    modal.style.display = 'flex';
  } catch (err) {
    console.error('학급 도감 로딩 실패:', err);
  }
}

loadStudents();
</script>
</body>
</html>
